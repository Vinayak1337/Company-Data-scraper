# Django
SECRET_KEY=dev-only-change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=UTC

# Optional single-user API guard for deployed personal instances.
# Keep disabled for local development unless your frontend also has BACKEND_API_TOKEN.
JOB_SCOUT_REQUIRE_AUTH=False
JOB_SCOUT_API_TOKEN=

# Agent runtime execution. Use queued with a worker running:
# python manage.py process_agent_queue --limit 5
AGENT_EXECUTION_MODE=inline
AGENT_QUEUE_BATCH_SIZE=5
JOB_SCOUT_RUNTIME_ENV=local
JOB_SCOUT_BRAIN_PROVIDER=direct_api
JOB_SCOUT_ENABLE_LOCAL_CLI=False
JOB_SCOUT_CLI_TIMEOUT_SECONDS=120

# Database
# Leave blank for local SQLite. Use a Postgres URL in production.
DATABASE_URL=
# Use disable for local Docker Postgres. Use require for managed Postgres unless the URL already has sslmode.
DATABASE_SSLMODE=

# Scraping
SCRAPER_USER_AGENT=CompanyJobScraper/1.0 (+https://github.com/self-hosted-job-scraper)
SCRAPER_TIMEOUT_SECONDS=20
# Set true on the Django backend when a scanner worker/process is deployed.
SCANNER_ENABLED=False

# AI providers. Optional; do not commit real values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# Local-only CLI brain commands. Configure with: ./scripts/job-scout providers
JOB_SCOUT_GEMINI_CLI_COMMAND="gemini -p {prompt}"
JOB_SCOUT_CLAUDE_CODE_CLI_COMMAND="claude -p {prompt}"
JOB_SCOUT_CODEX_CLI_COMMAND="codex exec {prompt}"
JOB_SCOUT_OPENCODE_COMMAND="opencode run {prompt}"

# Optional AI observability. LangSmith is framework-agnostic here; LangChain is not required.
LANGSMITH_TRACING=False
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=job-scout-v2

# Optional email/SMPP-style settings for future notification delivery.
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional MTEANE event automation service. Disabled by default.
MTEANE_ENABLED=False
MTEANE_API_URL=
MTEANE_API_KEY=
MTEANE_TIMEOUT_SECONDS=3
